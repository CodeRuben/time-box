// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  role          String    @default("USER")
  accounts      Account[]
  sessions      Session[]
  plannerDays   PlannerDay[]
  workoutDays   WorkoutDay[]
  tasks         Task[]
  featurePreferences UserFeaturePreference[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model FeatureFlag {
  key          String   @id
  adminEnabled Boolean  @default(true)
  userEnabled  Boolean  @default(true)
  guestEnabled Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserFeaturePreference {
  id         String   @id @default(cuid())
  userId     String
  featureKey String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PlannerDay {
  id        String   @id @default(cuid())
  userId    String
  date      String
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model WorkoutDay {
  id        String   @id @default(cuid())
  userId    String
  date      String
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Task {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String   @default("")
  // Stored as a JSON-encoded array of { id, name, completed }. SQLite lacks a
  // native JSON column, so we validate at the API boundary (see
  // `lib/task-api-helpers.ts`) before writing.
  checklist   String   @default("[]")
  // Enum-like values validated at the API boundary: "todo" | "in_progress" | "review" | "done".
  status      String   @default("todo")
  // Enum-like values validated at the API boundary: "work" | "personal".
  type        String   @default("personal")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

model RegistrationRateLimitBucket {
  key       String @id
  attempts  Int    @default(0)
  resetAtMs BigInt

  @@index([resetAtMs])
}
